{
  "name": "juraregel",
  "version": "1.0.0",
  "private": true,
  "description": "JuraRegel — Legal RuleOps Platform CLI",
  "type": "module",
  "bin": {
    "juraregel": "bin/juraregel.mjs"
  },
  "scripts": {
    "init": "node bin/juraregel.mjs init",
    "check": "node bin/juraregel.mjs check",
    "serve": "node bin/juraregel.mjs serve",
    "test": "PYTHON=.venv/bin/python; [ -x \"$PYTHON\" ] || PYTHON=python3; \"$PYTHON\" -m pytest use-cases/*/tests/ ci/test_*.py mcp-server/test_*.py features/ sources/test_*.py shared/test_*.py tools/test_*.py tools/rule-extraction/test_*.py governance/test_*.py -q --no-header",
    "sdk:check": "npm --prefix sdk/typescript run check"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/djimit/juraregel"
  },
  "keywords": [
    "juraregel",
    "legal-ruleops",
    "compliance",
    "netherlands",
    "bio2",
    "nora",
    "ai-act",
    "avg"
  ]
}
