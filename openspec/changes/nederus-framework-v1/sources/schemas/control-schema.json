{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nederus-framework.nl/schemas/control-schema-v1.json",
  "title": "NEDERUS Control Catalog",
  "description": "Schema for NEDERUS unified AI governance control catalog",
  "type": "object",
  "required": ["version", "last_updated", "frameworks", "controls"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semver version of this control catalog"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date of last modification"
    },
    "frameworks": {
      "type": "object",
      "description": "Version-locked framework references",
      "required": ["nist_ai_rmf", "eu_ai_act", "bio2", "nis2", "nora"],
      "properties": {
        "nist_ai_rmf": { "type": "string" },
        "eu_ai_act": { "type": "string" },
        "bio2": { "type": "string" },
        "nis2": { "type": "string" },
        "nora": { "type": "string" }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/control"
      }
    }
  },
  "definitions": {
    "control": {
      "type": "object",
      "required": ["id", "title", "description", "severity", "frameworks", "evidence_required", "implementation_guidance"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^NED-[0-9]{2}$",
          "description": "Unique control identifier"
        },
        "title": {
          "type": "string",
          "minLength": 5,
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "minLength": 20
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated"],
          "default": "active"
        },
        "frameworks": {
          "type": "object",
          "required": ["nist_ai_rmf", "eu_ai_act", "bio2", "nis2", "nora"],
          "properties": {
            "nist_ai_rmf": { "$ref": "#/definitions/framework_ref" },
            "eu_ai_act": { "$ref": "#/definitions/framework_ref" },
            "bio2": { "$ref": "#/definitions/framework_ref" },
            "nis2": { "$ref": "#/definitions/framework_ref" },
            "nora": { "$ref": "#/definitions/framework_ref" }
          },
          "additionalProperties": false
        },
        "evidence_required": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 5 }
        },
        "implementation_guidance": {
          "type": "string",
          "minLength": 20
        }
      },
      "additionalProperties": false
    },
    "framework_ref": {
      "type": "object",
      "required": ["reference", "relation"],
      "properties": {
        "function": {
          "type": "string",
          "description": "NIST RMF function (GOVERN, MAP, MEASURE, MANAGE) — NIST only"
        },
        "reference": {
          "type": "string",
          "description": "Article/section reference in source framework"
        },
        "relation": {
          "type": "string",
          "enum": ["equivalent", "partial", "gap"],
          "description": "Mapping relation: equivalent (1:1), partial (overlap), gap (no correlate)"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
