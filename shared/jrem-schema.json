{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rechtspraak.nl/jrem/schema/v1.0.0",
  "title": "Judicial Rule Exchange Model (JREM)",
  "description": "Neutraal uitwisselmodel voor juridische regels. Primair contract tussen RegelSpraak specificatie en Rule API.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "ruleSetId",
    "version",
    "validFrom",
    "validUntil",
    "jurisdiction",
    "domain",
    "procedureType",
    "conflictResolution",
    "rules"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Versie van het JREM-schema zelf",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "ruleSetId": {
      "type": "string",
      "description": "Unieke identificatie van de ruleset"
    },
    "version": {
      "type": "string",
      "description": "Versie van de tariefset",
      "pattern": "^\\d{4}\\.\\d+$"
    },
    "validFrom": {
      "type": "string",
      "format": "date",
      "description": "Geldig vanaf (ISO 8601 datum)"
    },
    "validUntil": {
      "type": "string",
      "format": "date",
      "description": "Geldig tot en met (ISO 8601 datum)"
    },
    "jurisdiction": {
      "type": "string",
      "description": "Jurisdictie (ISO 3166-1 alpha-2)"
    },
    "domain": {
      "type": "string",
      "enum": [
        "civiel-rechtbank",
        "civiel-gerechtshof",
        "bestuursrecht",
        "strafrecht",
        "rechtspraak-publicatie",
        "bio2-informatiebeveiliging",
        "forumstandaardisatie",
        "overheidsstandaarden",
        "nora-architectuur",
        "eu-ai-act",
        "avg-gdpr",
        "ncsc-cybersecurity",
        "nis2",
        "btw-tarieven",
        "ww-uitkering",
        "ind-verblijfsregels",
        "wmo",
        "gegevensdelingsbeleid",
        "dpia-model",
        "algoritmeregister",
        "data-overheid-dcat",
        "api-registratie"
      ]
    },
    "procedureType": {
      "type": "string",
      "enum": [
        "dagvaarding",
        "verzoek",
        "kort-geding",
        "cassatie"
      ]
    },
    "conflictResolution": {
      "type": "string",
      "enum": [
        "first-match",
        "highest-priority",
        "manual"
      ]
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ruleId",
          "name",
          "priority",
          "legalStatus",
          "sourceRefs",
          "conditions",
          "outcome"
        ],
        "properties": {
          "ruleId": {
            "type": "string",
            "description": "Unieke identificatie van de regel"
          },
          "name": {
            "type": "string",
            "description": "Leesbare naam van de regel"
          },
          "priority": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000,
            "description": "Prioriteit: hoger = eerder geëvalueerd bij first-match"
          },
          "legalStatus": {
            "type": "string",
            "enum": [
              "wettelijk",
              "regeling",
              "conventie"
            ],
            "description": "Juridische status van de regel"
          },
          "sourceRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type",
                "title"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "wetsartikel",
                    "regeling",
                    "rechtspraak-tarieftabel",
                    "procesreglement",
                    "jurisprudentie"
                  ]
                },
                "title": {
                  "type": "string"
                },
                "section": {
                  "type": "string"
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          },
          "conditions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "zaakstroom": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "kanton",
                    "handel"
                  ]
                }
              },
              "rol": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "eiser",
                    "gedaagde",
                    "verzoeker",
                    "verweerder"
                  ]
                }
              },
              "partijType": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "natuurlijk_persoon",
                    "niet_natuurlijk_persoon",
                    "onvermogend"
                  ]
                }
              },
              "verweerStatus": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "niet_ingediend",
                    "ingediend",
                    "onbekend",
                    "n.v.t."
                  ]
                }
              },
              "bijzondereCategorie": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "geen",
                    "whoa",
                    "depot",
                    "akte"
                  ]
                }
              },
              "vorderingWaarde": {
                "oneOf": [
                  {
                    "type": "string",
                    "enum": [
                      "onbepaald"
                    ]
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "gt": {
                        "type": "number",
                        "minimum": 0
                      },
                      "gte": {
                        "type": "number",
                        "minimum": 0
                      },
                      "lt": {
                        "type": "number",
                        "minimum": 0
                      },
                      "lte": {
                        "type": "number",
                        "minimum": 0
                      }
                    },
                    "minProperties": 1
                  }
                ]
              }
            }
          },
          "outcome": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "griffierecht",
              "confidence",
              "manualReviewRequired"
            ],
            "properties": {
              "griffierecht": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "amount",
                  "currency"
                ],
                "properties": {
                  "amount": {
                    "type": [
                      "number",
                      "null"
                    ],
                    "minimum": 0,
                    "description": "Griffierecht bedrag in euro's, of null indien niet van toepassing"
                  },
                  "currency": {
                    "type": "string",
                    "enum": [
                      "EUR"
                    ]
                  }
                }
              },
              "category": {
                "type": "string",
                "description": "Tariefcategorie"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "deterministic",
                  "probabilistic"
                ]
              },
              "manualReviewRequired": {
                "type": "boolean"
              },
              "manualReviewReason": {
                "type": "string"
              }
            }
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "input",
                "expectedAmount"
              ],
              "properties": {
                "input": {
                  "type": "object",
                  "additionalProperties": true
                },
                "expectedAmount": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "input",
          "expected"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "input": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "rechtsgebied",
              "zaakstroom",
              "procedureType",
              "vorderingWaarde"
            ],
            "properties": {
              "rechtsgebied": {
                "type": "string"
              },
              "zaakstroom": {
                "type": "string"
              },
              "procedureType": {
                "type": "string"
              },
              "vorderingWaarde": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "bijzondereCategorie": {
                "type": "string"
              },
              "rol": {
                "type": "string"
              },
              "partijType": {
                "type": "string"
              },
              "onvermogend": {
                "type": "boolean"
              },
              "verweerStatus": {
                "type": "string"
              }
            }
          },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "griffierecht",
              "category",
              "appliedRules"
            ],
            "properties": {
              "griffierecht": {
                "type": "number",
                "minimum": 0
              },
              "category": {
                "type": "string"
              },
              "appliedRules": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "manualReviewRequired": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "transitionRules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from",
          "to",
          "effectiveDate",
          "description"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "effectiveDate": {
            "type": "string",
            "format": "date"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optionele metadata voor juridische context en acceptatie",
      "properties": {
        "juridischeContext": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "wet": {
              "type": "string"
            },
            "wetBwbrId": {
              "type": "string"
            },
            "wetVersieLaatstGecheckt": {
              "type": "string",
              "format": "date"
            },
            "tariefVersie": {
              "type": "string"
            }
          }
        },
        "juristAccordering": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "geaccondeerdDoor": {
              "type": "string"
            },
            "datum": {
              "type": "string",
              "format": "date"
            },
            "geldigTot": {
              "type": "string",
              "format": "date"
            },
            "versie": {
              "type": "string"
            }
          }
        },
        "bronverificatieDatum": {
          "type": "string",
          "format": "date"
        },
        "acceptatieType": {
          "type": "string",
          "enum": [
            "draft",
            "full",
            "update"
          ]
        }
      }
    }
  }
}