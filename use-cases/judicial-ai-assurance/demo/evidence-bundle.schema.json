{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://djimit.nl/schemas/judicial-ai-evidence-demo-v1.json",
  "title": "JuraRegel Judicial AI Evidence Demo",
  "type": "object",
  "required": ["schemaVersion", "profile", "disclaimer", "scenarios", "bundleHash"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "profile": {
      "type": "object",
      "required": ["domain", "version", "status", "ruleCount", "hardStopCount", "sourceHash"],
      "properties": {
        "domain": {"const": "judicial-ai-assurance"},
        "version": {"type": "string"},
        "status": {"type": "string"},
        "ruleCount": {"const": 12},
        "hardStopCount": {"const": 9},
        "sourceHash": {"$ref": "#/$defs/hash"}
      },
      "additionalProperties": false
    },
    "disclaimer": {"type": "string", "minLength": 1},
    "scenarios": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["scenarioId", "title", "summary", "expectedBoundary", "status", "blockedControls", "humanDecision", "controls", "evidence"],
        "properties": {
          "scenarioId": {"type": "string"},
          "title": {"type": "string"},
          "summary": {"type": "string"},
          "expectedBoundary": {"enum": ["blocked", "review-required", "conditionally-admissible"]},
          "status": {"enum": ["blocked", "review-required", "conditionally-admissible"]},
          "blockedControls": {"type": "array", "items": {"pattern": "^JAI-[0-9]{3}$"}},
          "humanDecision": {
            "oneOf": [
              {"type": "null"},
              {"$ref": "#/$defs/humanDecision"}
            ]
          },
          "controls": {
            "type": "array",
            "minItems": 12,
            "maxItems": 12,
            "items": {"$ref": "#/$defs/control"}
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sourceSystem", "status", "artifactRef", "summary", "artifactTypes", "id", "recordHash"],
              "properties": {
                "sourceSystem": {"type": "string", "minLength": 1},
                "status": {"enum": ["observed", "failed"]},
                "runId": {"type": "string"},
                "artifactRef": {"type": "string", "minLength": 1},
                "summary": {"type": "string", "minLength": 1},
                "artifactTypes": {"type": "array", "minItems": 1, "items": {"type": "string"}},
                "id": {"type": "string", "pattern": "^E-[0-9]{3}$"},
                "artifactHash": {"$ref": "#/$defs/hash"},
                "recordHash": {"$ref": "#/$defs/hash"}
              },
              "additionalProperties": false
            }
          }
        }
      }
    },
    "bundleHash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "humanDecision": {
      "type": "object",
      "required": ["decision", "profileVersion", "actor", "role", "reason"],
      "properties": {
        "decision": {"enum": ["approved", "rejected"]},
        "profileVersion": {"type": "string"},
        "actor": {"type": "string", "minLength": 1},
        "role": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "control": {
      "type": "object",
      "required": ["controlId", "name", "controlClass", "status", "missingEvidence", "failedEvidence", "evidenceRefs"],
      "properties": {
        "controlId": {"pattern": "^JAI-[0-9]{3}$"},
        "name": {"type": "string", "minLength": 1},
        "controlClass": {"enum": ["hard-stop", "required-evidence"]},
        "status": {"enum": ["blocked", "review-required"]},
        "missingEvidence": {"type": "array", "items": {"type": "string"}},
        "failedEvidence": {"type": "array", "items": {"type": "string"}},
        "evidenceRefs": {"type": "array", "items": {"pattern": "^E-[0-9]{3}$"}}
      },
      "additionalProperties": false
    }
  }
}
