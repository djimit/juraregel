# DPIA Generator RegelSpraak Specificatie
# Data Protection Impact Assessment — Volledige document-generatie
#
# Implementeert:
# - EDPB DPIA Template 2026 (7 secties: 0-6)
# - Autoriteit Persoonsgegevens DPIA-checklist + verplichte lijst
# - KCBR Model DPIA Rijksdienst (4 delen: A-D)
# - AVG Art. 35 lid 7a-f (minimum inhoud DPIA)
#
# Bronnen:
# - https://www.edpb.europa.eu/public-consultations/template-for-data-protection-impact-assessment_en
# - https://www.autoriteitpersoonsgegevens.nl/en/themes/basic-gdpr/gdpr-in-practice/data-protection-impact-assessment-dpia
# - https://www.kcbr.nl/ontwikkelen-beleid-en-regelgeving/beleidskompas/verplichte-kwaliteitseisen/data-protection-impact-assessment

# ═══════════════════════════════════════════════════════════════
# SECTIE 0: DPIA TECHNICAL SHEET (EDPB Sectie 0)
# ═══════════════════════════════════════════════════════════════

regel DPG-001 "DPG-001 DPIA technische fiche verplicht":
  als dpiaVersion is leeg
  dan is compliant nee
  en is sectie "0_technical_sheet"
  en is actie "Vul DPIA-versie, datum, auteur en goedkeuring in"
  en is verplicht "ja"
  en is bron "EDPB Template Sectie 0 + AVG Art. 35 lid 7".

regel DPG-002 "DPG-002 Versiebeheer DPIA":
  als dpiaVersieLog is leeg
  dan is compliant nee
  en is sectie "0_technical_sheet"
  en is actie "Documenteer wijzigingshistorie (versie, datum, wijziging, auteur)"
  en is verplicht "ja"
  en is bron "EDPB Template Sectie 0.5: Version log".

# ═══════════════════════════════════════════════════════════════
# SECTIE 1: CONTEXT VAN DE VERWERKING (EDPB Sectie 1 + KCBR Deel A)
# ═══════════════════════════════════════════════════════════════

regel DPG-010 "DPG-010 Verwerkingsbeschrijving verplicht":
  als verwerkingsDoel is leeg
  dan is compliant nee
  en is sectie "1_context"
  en is actie "Beschrijf het doel van de verwerking"
  en is verplicht "ja"
  en is bron "EDPB Template Sectie 1.1 + AVG Art. 35 lid 7a".

regel DPG-011 "DPG-011 Verantwoordelijke identificatie":
  als verantwoordelijke is leeg
  dan is compliant nee
  en is sectie "1_context"
  en is actie "Identificeer de verwerkingsverantwoordelijke (naam, contact)"
  en is verplicht "ja"
  en is bron "EDPB Template Sectie 1.2 + AVG Art. 4(7)".

regel DPG-012 "DPG-012 Gegevenscategorieen verplicht":
  als gegevensCategorieen is leeg
  dan is compliant nee
  en is sectie "1_context"
  en is actie "Lijst alle verwerkte gegevenscategorieen"
  en is verplicht "ja"
  en is bron "EDPB Template Sectie 1.3 + AVG Art. 35 lid 7a".

regel DPG-013 "DPG-013 Betrokkenen categorieen":
  als betrokkenen is leeg
  dan is compliant nee
  en is sectie "1_context"
  en is actie "Identificeer categorieen betrokkenen (burgers, werknemers, kinderen)"
  en is verplicht "ja"
  en is bron "EDPB Template Sectie 1.4".

regel DPG-014 "DPG-014 Rechtsgrond verplicht":
  als rechtsgrond is leeg
  dan is compliant nee
  en is sectie "1_context"
  en is actie "Geef de rechtsgrond voor de verwerking (Art. 6 AVG)"
  en is verplicht "ja"
  en is bron "EDPB Template Sectie 1.5 + AVG Art. 6".

regel DPG-015 "DPG-015 Bewaartermijn":
  als bewaartermijn is leeg
  dan is compliant nee
  en is sectie "1_context"
  en is actie "Specificeer de bewaartermijn per gegevenscategorie"
  en is verplicht "ja"
  en is bron "EDPB Template Sectie 1.6 + AVG Art. 5 lid 1e".

regel DPG-016 "DPG-016 Gegevensontvangers":
  als ontvangers is leeg
  dan is compliant nee
  en is sectie "1_context"
  en is actie "Lijst ontvangers van de gegevens (intern, extern, derde landen)"
  en is verplicht "ja"
  en is bron "EDPB Template Sectie 1.7 + AVG Art. 13 lid 1e".

regel DPG-017 "DPG-017 Derde landen transfer":
  als derdeLanden is "ja"
  als beschermingsNiveau is leeg
  dan is compliant nee
  en is sectie "1_context"
  en is actie "Documenteer passende waarborgen (BCR, SCC, adequaat besluit)"
  en is verplicht "ja"
  en is bron "EDPB Template Sectie 1.8 + AVG Art. 44-49".

regel DPG-018 "DPG-018 Verwerkingsactiviteiten overzicht":
  als verwerkingsActiviteiten is leeg
  dan is compliant nee
  en is sectie "1_context"
  en is actie "Beschrijf de verwerkingsactiviteiten (verzamelen, opslaan, delen, wissen)"
  en is verplicht "ja"
  en is bron "KCBR Deel A: Beschrijving feitelijke situatie".

# ═══════════════════════════════════════════════════════════════
# SECTIE 2: ESSENTIEEL — DREMPELTOETS (EDPB Sectie 2 + AP-Checklist)
# ═══════════════════════════════════════════════════════════════

regel DPG-020 "DPG-020 Drempeltoets verplicht":
  als dpiaVerplicht is leeg
  dan is compliant nee
  en is sectie "2_essentieel"
  en is actie "Voer drempeltoets uit: raadpleeg AP-lijst + 9-criteria AVG Art. 35(3)"
  en is verplicht "ja"
  en is bron "AP DPIA-checklist + AVG Art. 35 lid 3".

regel DPG-021 "DPG-021 AP-lijst check":
  als opApLijst is leeg
  dan is compliant nee
  en is sectie "2_essentieel"
  en is actie "Check of verwerking op AP-lijst staat (12 categorien)"
  en is verplicht "ja"
  en is bron "AP-lijst: https://www.autoriteitpersoonsgegevens.nl/documenten/lijst-verplichte-dpia".

regel DPG-022 "DPG-022 Negen criteria AVG Art. 35(3)":
  als criteriaScore < 2
  dan is compliant nee
  en is sectie "2_essentieel"
  en is actie "Evalueer 9 criteria: systematische beoordeling, grootschalig, bijzondere categorie, gevangenis, nieuwe tech, kwetsbare groepen, innovatieve gebruik, hindering toegang, profiling"
  en is verplicht "ja"
  en is bron "AVG Art. 35 lid 3a-3c + AP-richtlijnen".

regel DPG-023 "DPG-023 Pre-scan DPIA (KCBR)":
  als preScanUitgevoerd is "nee"
  dan is compliant nee
  en is sectie "2_essentieel"
  en is actie "Voer pre-scan DPIA uit (KCBR Model DPIA Rijksdienst)"
  en is verplicht "ja"
  en is bron "KCBR: Pre-scan DPIA + Model DPIA Rijksdienst".

regel DPG-024 "DPG-024 DPIA niet verplicht — documenteer":
  als dpiaVerplicht is "nee"
  dan is compliant ja
  en is sectie "2_essentieel"
  en is actie "Documenteer waarom DPIA niet verplicht is (bewijs)"
  en is verplicht "ja"
  en is bron "AVG Art. 35 lid 1 + AP-richtlijnen".

