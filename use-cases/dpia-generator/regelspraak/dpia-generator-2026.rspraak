  en is bron "EDPB Template Sectie 3.3 + KCBR Deel B".

regel DPG-033 "DPG-033 Data minimalisatie":
  als dataMinimalisatie is "nee"
  dan is compliant nee
  en is sectie "3_noodzaak"
  en is actie "Minimaliseer gegevensverwerking (alleen wat noodzakelijk)"
  en is verplicht "ja"
  en is bron "AVG Art. 5 lid 1c + EDPB Template Sectie 3.4".

regel DPG-034 "DPG-034 Doelbinding":
  als doelbinding is "nee"
  dan is compliant nee
  en is sectie "3_noodzaak"
  en is actie "Gegevens alleen voor gespecificeerde doeleinden gebruiken"
  en is verplicht "ja"
  en is bron "AVG Art. 5 lid 1b".

