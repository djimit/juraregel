        {
          "type": "wet",
          "title": "Omgevingswet",
          "section": "art. 5.1"
        },
        {
          "type": "besluit",
          "title": "Besluit activiteiten leefomgeving (Bal)",
          "section": "art. 2.1"
        }
      ],
      "conditions": {
        "activiteit": "bouwen",
        "bouwhoogte": {
          "gt": 5
        }
      },
      "outcome": {
        "vergunningplichtig": true,
        "type": "omgevingsvergunning",
